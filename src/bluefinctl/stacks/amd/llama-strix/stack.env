STACK_ORDER=5
STACK_ICON=⚡
STACK_NAME=Llama Strix
STACK_ARCH=strix-halo
STACK_DESC=Strix Halo optimized llama.cpp — gfx1151 unified memory up to 124 GB
STACK_LONG_DESC=Built specifically for Strix Halo APUs (Ryzen AI MAX series, gfx1151). Exploits unified memory to run models up to 124 GB — larger than any discrete GPU. Uses ROCm 7.2.4 with flash-attn (-fa 1) and --no-mmap flags that are required on Strix Halo for stability and full performance. Best choice for Ryzen AI MAX 395 and similar hardware. Serves via OpenAI-compatible API on port 8080.
STACK_CATEGORY=serve
STACK_VRAM_GB=8
STACK_DISK_GB=5
STACK_PORTS=api:8080
STACK_REQUIRES_HF_AUTH=false
LLAMA_MODEL=/workspace/models/model.gguf
