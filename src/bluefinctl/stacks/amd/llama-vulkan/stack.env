STACK_ORDER=15
STACK_ICON=🌋
STACK_NAME=Llama Vulkan
STACK_ARCH=strix-halo
STACK_DESC=Vulkan/RADV llama.cpp — no ROCm needed, widest AMD GPU compatibility
STACK_LONG_DESC=Runs llama.cpp via Vulkan/RADV — no ROCm or /dev/kfd required. Compatible with any RDNA2+ AMD GPU, including cards that cannot run ROCm. From the Strix Halo Toolboxes project and optimized for Strix Halo, but works broadly across AMD hardware. The safest fallback if ROCm stacks fail on your system. Serves via OpenAI-compatible API on port 8080.
STACK_CATEGORY=serve
STACK_VRAM_GB=4
STACK_DISK_GB=4
STACK_PORTS=api:8080
STACK_REQUIRES_HF_AUTH=false
LLAMA_MODEL=/workspace/models/model.gguf
