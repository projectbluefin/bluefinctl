STACK_ORDER=10
STACK_ICON=🦙
STACK_NAME=RamaLama
STACK_DESC=OCI-native ROCm LLM server — pull any model from HuggingFace or OCI
STACK_LONG_DESC=Container-native LLM server from the Red Hat containers team. Auto-detects ROCm hardware and selects the right backend automatically. Serves llama3.2:3b by default via OpenAI-compatible API on port 8080. Supports pulling models from ollama://, huggingface://, and OCI registries — change the model by editing the Exec line in ~/.config/containers/systemd/ramalama.container.
STACK_CATEGORY=serve
STACK_VRAM_GB=4
STACK_DISK_GB=3
STACK_PORTS=api:8080
STACK_REQUIRES_HF_AUTH=false
RAMALAMA_MODEL=ollama://llama3.2:3b
